{
  "name": "@jocelyn-stericker/espeak-phonemes",
  "version": "0.0.0",
  "description": "English text to IPA phonemes using eSpeak NG — WASM-based, fast, offline",
  "type": "module",
  "module": "./dist/esm/index.js",
  "types": "./dist/esm/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/esm/index.d.ts",
      "import": "./dist/esm/index.js"
    },
    "./espeak-phonemes.js": "./espeak-phonemes.js",
    "./espeak-phonemes.wasm": "./espeak-phonemes.wasm",
    "./espeak-ng-data.tar.gz": "./espeak-ng-data.tar.gz",
    "./package.json": "./package.json"
  },
  "files": [
    "dist/",
    "src/",
    "espeak-phonemes.wasm",
    "espeak-phonemes.js",
    "espeak-ng-data.tar.gz",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "bash scripts/build.sh",
    "build:ts": "tsc -p tsconfig.json",
    "clean": "rm -rf dist espeak-phonemes.wasm espeak-phonemes.js espeak-ng-data.tar.gz",
    "test:golden": "node tests/test-golden-corpus.mjs",
    "test:smoke": "node tests/test-smoke.mjs",
    "check-size": "node tests/check-size.mjs"
  },
  "license": "AGPL-3.0-or-later",
  "repository": {
    "type": "git",
    "url": "https://codeberg.org/jocelyn-stericker/espeak-phonemes.git"
  },
  "publishConfig": {
    "registry": "https://codeberg.org/api/packages/jocelyn-stericker/npm/"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "typescript": "^6.0.3"
  }
}
