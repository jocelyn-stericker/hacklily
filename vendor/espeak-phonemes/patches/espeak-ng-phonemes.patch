+// wavegen.c stubs
+
+int embedded_value[N_EMBEDDED_VALUES];
+const int embedded_default[N_EMBEDDED_VALUES] = { 0, 50, espeakRATE_NORMAL, 100, 50, 0, 0, 0, espeakRATE_NORMAL, 0, 0, 0, 0, 0, 0 };
+
+int samplerate = 22050;
+unsigned char *out_ptr = NULL;
+unsigned char *out_end = NULL;
+
+intptr_t wcmdq[N_WCMDQ][4];
+int wcmdq_head = 0;
+int wcmdq_tail = 0;
+
+int echo_head = 0;
+int echo_tail = 0;
+int echo_amp = 0;
+short echo_buf[N_ECHO_BUF];
+
+void WavegenInit(int rate, int wavemult_fact)
+{
+	(void)rate;
+	(void)wavemult_fact;
+	samplerate = rate > 0 ? rate : 22050;
+}
+
+void WavegenFini(void)
+{
+}
+
+void InitBreath(void)
+{
+}
+
+void WavegenSetVoice(voice_t *v)
+{
+	(void)v;
+}
+
+void Write4Bytes(FILE *f, int value)
+{
+	int ix;
+	for (ix = 0; ix < 4; ix++) {
+		fputc(value & 0xff, f);
+		value = value >> 8;
+	}
+}
+
+int WavegenFill(void)
+{
+	return 0;
+}
+
+int WcmdqUsed(void)
+{
+	return 0;
+}
