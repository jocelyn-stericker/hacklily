{
  "name": "braat",
  "private": true,
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "vite dev --port 3000",
    "build": "rm -fr dist; vite build",
    "preview": "vite preview",
    "test": "vitest run --tags-filter=!e2e",
    "e2e": "vitest run --tags-filter=e2e",
    "synth:references": "npm --prefix tools/synth-references install && npm --prefix tools/synth-references run synth --",
    "media:fetch": "tsx tools/fetch-media.ts",
    "mem": "tsx mem/run.ts",
    "mem:detail": "tsx mem/run.ts --layer2",
    "lint": "oxlint && oxfmt --check .",
    "check": "oxfmt . && oxlint --fix"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.0",
    "@huggingface/transformers": "^4.2.0",
    "@jocelyn-stericker/espeak-phonemes": "0.0.6",
    "@jocelyn-stericker/ort-silero-vad-wasm-minimal": "0.0.23",
    "@mediabunny/mp3-encoder": "^1.49.0",
    "@tailwindcss/vite": "^4.3.1",
    "@tanstack/react-router": "^1.169.2",
    "@tanstack/router-plugin": "^1.132.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "fflate": "^0.8.3",
    "lucide-react": "^1.17.0",
    "mediabunny": "^1.49.0",
    "next-themes": "^0.4.6",
    "onnxruntime-web": "^1.26.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-hotkeys-hook": "^5.3.2",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.3.1",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2"
  },
  "overrides": {
    "@huggingface/transformers": {
      "onnxruntime-node": "file:vendor/empty",
      "sharp": "file:vendor/empty"
    }
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@rolldown/plugin-babel": "^0.2.3",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.0",
    "@types/dom-speech-recognition": "^0.0.12",
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.7",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "happy-dom": "^20.10.6",
    "oxfmt": "^0.55.0",
    "oxlint": "^1.64.0",
    "oxlint-tsgolint": "^0.23.0",
    "standardized-audio-context-mock": "^10.0.0",
    "tsx": "^4.22.4",
    "vite": "^8.0.0",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.5"
  }
}
