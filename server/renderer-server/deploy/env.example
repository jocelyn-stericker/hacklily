# Hacklily renderer server configuration.
#
# Copy to ~/.config/hacklily-renderer/env and edit. Read by the
# hacklily-renderer systemd user service via EnvironmentFile=.
#
# This file contains GitHub OAuth secrets, so keep it readable only by
# yourself:  chmod 600 ~/.config/hacklily-renderer/env
#
# systemd EnvironmentFile syntax: KEY=VALUE, no quotes, no spaces
# around '=', '#' starts a comment.

# --- Coordinator ---
# Port to listen on for frontend + remote ws-worker connections.
# In production this sits behind a TLS-terminating reverse proxy that
# forwards plain ws:// to this port.
WS_PORT=2000

# GitHub OAuth app credentials. Leave both empty to disable GitHub
# save/publish (the frontend still renders).
GITHUB_CLIENT_ID=
GITHUB_SECRET=

# --- Local render pool ---
# Docker image tags to use. These are LOCAL tags: update.sh pulls from
# the Codeberg Container Registry and retags to these names. The
# service never pulls on start, so these images must already exist
# locally (install.sh / update.sh put them there).
STABLE_DOCKER_TAG=hacklily-renderer:latest
UNSTABLE_DOCKER_TAG=hacklily-renderer-unstable:latest

# Number of warm renderer containers to keep in the pool per version.
# Set to 0 for pure-coordinator mode (renders dispatch to remote
# ws-worker peers; requests fail if none are attached).
STABLE_WORKER_COUNT=1
UNSTABLE_WORKER_COUNT=1

# Per-request render timeout in milliseconds. The inner LilyPond
# worker timeout is derived from this. Must be below
# TimeoutStopSec in the unit file (minus a margin) so a graceful
# shutdown can finish one last render.
RENDER_TIMEOUT_MSEC=8000

# --- Logging ---
# env_logger filter. Overrides the -v flags. Examples: info, debug,
# "info,renderer_lib=debug". See https://docs.rs/env_logger
RUST_LOG=info