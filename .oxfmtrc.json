{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "semi": false,
  "singleQuote": true,
  "trailingComma": "all",
  "printWidth": 80,
  "sortImports": true,
  "sortPackageJson": false,
  "ignorePatterns": [
    "package-lock.json",
    "pnpm-lock.yaml",
    "yarn.lock",
    "src/routeTree.gen.ts",
    "src/vendor/**",
    "vendor/**"
  ]
}
