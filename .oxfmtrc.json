{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "semi": true,
  "singleQuote": false,
  "trailingComma": "all",
  "printWidth": 80,
  "sortImports": true,
  "sortPackageJson": false,
  "ignorePatterns": [
    "package-lock.json",
    "pnpm-lock.yaml",
    "yarn.lock",
    "static/**",
    "src/vendor/**",
    "src/__mocks__/**",
    "src/musicxml-interfaces/private/writeBuilders.js"
  ]
}
